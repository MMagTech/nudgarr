# Nudgarr Environment Configuration
# Copy this file to .env and fill in your values before starting the container.
#
# PUID / PGID — run the container as the correct user for your platform
#   Unraid:   PUID=99  PGID=100  (nobody:users)
#   Linux:    PUID=1000 PGID=1000 (run `id` in terminal to find yours)
#   Synology: match your DSM user — check with `id` over SSH
#
PUID=1000
PGID=1000

# Port Nudgarr listens on — change if 8085 is already in use
PORT=8085

# Timezone for cron schedule evaluation — uses IANA timezone names
# Examples: America/New_York, Europe/London, Australia/Sydney
# Defaults to UTC if not set or unrecognised
TZ=UTC

# Path to your config storage directory on the host
CONFIG_PATH=/your/path/to/appdata/nudgarr

# Optional — override the auto-generated session secret key
# If not set, Nudgarr generates one automatically and persists it
# to /config/nudgarr-secret.key so sessions survive restarts.
# SECRET_KEY=your-random-string-here
